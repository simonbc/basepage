<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ site.title }}</title>
    {% if site.tagline %}<meta name="description" content="{{ site.tagline }}" />{% endif %}
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}" />
  </head>
  <body>
    <main class="card">
      <h1>{{ site.title }}</h1>
      <p class="tagline">{{ site.tagline }}</p>
      <nav class="links">
        <a href="#">Email</a>
        <a href="#">GitHub</a>
        <a href="#">Bluesky</a>
      </nav>
    </main>
  </body>
</html>
