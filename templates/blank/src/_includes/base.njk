<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} · {% endif %}{{ site.title }}</title>
    {% if description or site.tagline %}<meta name="description" content="{{ description or site.tagline }}" />{% endif %}
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}" />
    {% if 'rss' in site.features %}<link rel="alternate" type="application/atom+xml" href="{{ '/feed.xml' | url }}" title="{{ site.title }} — feed" />{% endif %}
  </head>
  <body>
    <main class="content">
      {{ content | safe }}
    </main>
  </body>
</html>
