---
layout: base.njk
---
<section class="intro">
  <h1>{{ site.title }}</h1>
  {% if site.tagline %}<p class="lede">{{ site.tagline }}</p>{% endif %}
</section>

{% if collections.posts | length %}
<ul class="post-list">
  {% for post in collections.posts %}
  <li>
    <a class="post-title" href="{{ post.url | url }}">{{ post.data.title }}</a>
    <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
    <p class="post-excerpt">{{ post.templateContent | excerpt(36) }}</p>
  </li>
  {% endfor %}
</ul>
{% else %}
<p>No posts yet. Run <code>basepage new post &lt;slug&gt;</code> to write one.</p>
{% endif %}
